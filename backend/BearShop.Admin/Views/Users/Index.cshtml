@model List<UserSummaryDto>
@{
    ViewData["Title"] = "Người dùng";
}

<div class="admin-card">
    <div class="fw-bold mb-3">Danh sách người dùng (@Model.Count)</div>

    @if (Model.Count == 0)
    {
        <div class="text-muted text-center py-5">Chưa có người dùng nào</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Điện thoại</th>
                        <th>Vai trò</th>
                        <th class="text-end">Số đơn</th>
                        <th>Trạng thái</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@u.Phone</td>
                            <td><span class="badge text-bg-light">@u.Role</span></td>
                            <td class="text-end">@u.OrderCount</td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge text-bg-success">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger">Đã khóa</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (u.Role != "Admin")
                                {
                                    <form asp-action="SetActive" asp-route-id="@u.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('@(u.IsActive ? "Khóa" : "Mở khóa") tài khoản &quot;@u.FullName&quot;?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="isActive" value="@(!u.IsActive)" />
                                        <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                            @(u.IsActive ? "Khóa" : "Mở khóa")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
