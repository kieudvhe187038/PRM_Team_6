@model ProductUpsertDto
@{
    ViewData["Title"] = "Thêm sản phẩm";
    var categories = (string[])ViewData["Categories"]!;
}

<div class="admin-card" style="max-width: 560px;">
    <div class="fw-bold mb-3">Thêm sản phẩm</div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="mb-3">
            <label class="form-label">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Danh mục</label>
            <select asp-for="Category" class="form-select">
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Giá (đ)</label>
                <input asp-for="Price" type="number" min="0" step="1000" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Tồn kho</label>
                <input asp-for="Stock" type="number" min="0" class="form-control" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Link ảnh sản phẩm</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
        </div>
        <div class="mb-3">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Hủy</a>
            <button type="submit" class="btn btn-primary flex-fill">Thêm sản phẩm</button>
        </div>
    </form>
</div>
