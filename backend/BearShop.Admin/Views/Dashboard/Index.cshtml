@model DashboardStatsDto
@{
    ViewData["Title"] = "Tổng quan";
    var maxRevenue = Model.RevenueLast7Days.Count > 0 ? Model.RevenueLast7Days.Max(d => d.Revenue) : 0;
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Doanh thu</div>
            <div class="stat-value">@Formatters.Vnd(Model.TotalRevenue)</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Đơn hàng</div>
            <div class="stat-value">@Model.TotalOrders</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Sản phẩm</div>
            <div class="stat-value">@Model.TotalProducts</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Khách hàng</div>
            <div class="stat-value">@Model.TotalCustomers</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-7">
        <div class="admin-card h-100">
            <div class="fw-bold mb-3">Doanh thu 7 ngày gần nhất</div>
            <div class="d-flex align-items-end gap-3" style="height: 160px;">
                @foreach (var day in Model.RevenueLast7Days)
                {
                    var heightPct = maxRevenue > 0 ? (day.Revenue / maxRevenue * 100) : 0;
                    <div class="d-flex flex-column align-items-center justify-content-end flex-fill h-100">
                        <div class="small text-muted mb-1">@Formatters.Vnd(day.Revenue)</div>
                        <div style="width: 100%; height: @(heightPct)%; min-height: 2px; background: var(--bear-primary); border-radius: 6px 6px 0 0;"></div>
                        <div class="small text-muted mt-1">@DateTime.Parse(day.Date).ToString("dd/MM")</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="admin-card h-100">
            <div class="fw-bold mb-3">Đơn hàng theo trạng thái</div>
            @if (Model.OrdersByStatus.Count == 0)
            {
                <div class="text-muted">Chưa có đơn hàng.</div>
            }
            else
            {
                foreach (var kv in Model.OrdersByStatus)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><span class="status-dot bg-secondary me-2"></span>@OrderStatuses.Label(kv.Key)</span>
                        <span class="fw-bold">@kv.Value</span>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-7">
        <div class="admin-card">
            <div class="fw-bold mb-3">Đơn hàng gần đây</div>
            @if (Model.RecentOrders.Count == 0)
            {
                <div class="text-muted">Chưa có đơn hàng.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr><th>Mã đơn</th><th>Người nhận</th><th>Trạng thái</th><th class="text-end">Tổng tiền</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.RecentOrders)
                            {
                                <tr>
                                    <td class="fw-bold">@o.Code</td>
                                    <td>@o.ReceiverName</td>
                                    <td><span class="badge @OrderStatuses.BadgeClass(o.Status)">@OrderStatuses.Label(o.Status)</span></td>
                                    <td class="text-end fw-bold" style="color: var(--bear-primary);">@Formatters.Vnd(o.Total)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    <div class="col-md-5">
        <div class="admin-card">
            <div class="fw-bold mb-3">Sản phẩm bán chạy</div>
            @if (Model.TopProducts.Count == 0)
            {
                <div class="text-muted">Chưa có dữ liệu.</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.TopProducts)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>@p.Name</span>
                            <span class="badge text-bg-light">Đã bán @p.Sold</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
